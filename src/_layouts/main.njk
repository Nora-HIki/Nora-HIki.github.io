<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/layout-styles/mainpage.css" />
    <link rel="stylesheet" href="/css/layout-styles/header.css" />
    <link rel="stylesheet" href="/css/layout-styles/leftbar.css" />
    <link rel="stylesheet" href="/css/layout-styles/middle.css" />
    <link rel="stylesheet" href="/css/layout-styles/rightbar.css" />
    <link rel="stylesheet" href="/css/layout-styles/footer.css" />
  </head>
  <body>
    <div id="mainpage">
      {% include "header.njk" %}

      <div class="mid-section">
        <aside class="left">{% include "leftbar.njk" %}</aside>
        <main class="center">{{ content | safe }}</main>
        <aside class="right">{% include "rightbar.njk" %}</aside>
      </div>
    
      {% include "footer.njk" %}
    </div> 
    <script src="/js/main.js"></script>
  </body>
</html>
